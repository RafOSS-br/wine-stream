# App profile: World of Warcraft 3.3.5a (WotLK)

# Prefix for the container name and named volumes (lowercase, no spaces).
APP_NAME=wow335

# Host directory with the application files, mounted read-only at /app.
APP_DIR=./samples/wow

# Executable to launch, relative to APP_DIR.
APP_EXE=Wow.exe

# Subdirectories needing persistent writes -> named volumes (<APP_NAME>-<dir>),
# seeded from APP_DIR/<dir> on first run.
APP_PERSIST="WTF"

# Subdirectories needing scratch writes -> tmpfs (<dir>:<size>), discarded on exit.
APP_SCRATCH="Cache:512m Logs:64m Errors:32m Screenshots:128m"

RESOLUTION=1920x1080
MEMORY=10g

# WoW notes:
# - WTF/Config.wtf must contain: SET gxCursor "0" — the client draws its own
#   cursor in-frame. Hardware cursors are invisible under headless capture
#   (XTest moves only the X11 pointer; the compositor never draws it).
#   The 3.3.5a cvar is gxCursor; "hardwareCursor" belongs to later expansions.
