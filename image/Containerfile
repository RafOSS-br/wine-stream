# wine-stream: hardened, rootless container for Windows executables.
# Stage 1: build the uinput->XTest shim (lets stock Sunshine inject input
#          without /dev/uinput — impossible rootless — by emulating the
#          uinput protocol in userspace over the X socket).
# Stage 2: lean runtime (Sway + Xwayland + Wine + DXVK + Mesa/VAAPI + Sunshine).

ARG SUNSHINE_VERSION=2026.516.143833

# ===== Stage 1: uinput shim =====
FROM registry.fedoraproject.org/fedora:43 AS shim-build
RUN dnf -y install gcc libX11-devel libXtst-devel && dnf clean all
COPY shim/uinput-shim.c /src/
RUN gcc -O2 -Wall -Wextra -shared -fPIC -o /src/uinput-shim.so /src/uinput-shim.c -lX11 -lXtst

# ===== Stage 2: runtime =====
FROM registry.fedoraproject.org/fedora:43

# RPM Fusion (mesa-va-drivers-freeworld: H264/HEVC encode)
RUN dnf install -y \
      https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
      https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm \
 && dnf clean all

# Sway + Xwayland + Wine + Mesa/VAAPI + debug tools (grim/xdotool/vulkan-tools)
RUN dnf install -y \
      sway \
      mesa-vulkan-drivers mesa-dri-drivers mesa-libGL vulkan-loader vulkan-tools \
      xorg-x11-server-Xwayland \
      libva libva-utils \
      pipewire pipewire-pulseaudio pipewire-utils wireplumber \
      wine winetricks \
      dbus-daemon \
      curl tar which procps-ng cabextract grim xdotool \
 && dnf clean all

RUN dnf swap -y mesa-va-drivers mesa-va-drivers-freeworld || \
    dnf install -y --allowerasing mesa-va-drivers-freeworld

# 32-bit libs for PE32 i386 executables under Wine with GPU
RUN dnf install -y \
      mesa-vulkan-drivers.i686 vulkan-loader.i686 \
      mesa-dri-drivers.i686 mesa-libGL.i686 alsa-lib.i686 \
 && dnf clean all

# Sunshine: official release RPM, pinned. Input comes from the uinput shim.
ARG SUNSHINE_VERSION
RUN dnf install -y \
      "https://github.com/LizardByte/Sunshine/releases/download/v${SUNSHINE_VERSION}/Sunshine-${SUNSHINE_VERSION}-1.fc$(rpm -E %fedora).x86_64.rpm" \
      libXtst \
 && dnf clean all

# uinput->XTest shim (LD_PRELOADed into Sunshine by the entrypoint)
COPY --from=shim-build /src/uinput-shim.so /usr/local/lib/uinput-shim.so
COPY shim/test-shim.py /usr/local/share/uinput-shim/test-shim.py

# DXVK (D3D8-D3D11 over Vulkan)
RUN set -eux; \
    curl -L -o /tmp/dxvk.tar.gz \
      https://github.com/doitsujin/dxvk/releases/download/v2.4.1/dxvk-2.4.1.tar.gz; \
    mkdir -p /opt; tar -C /opt -xf /tmp/dxvk.tar.gz; rm /tmp/dxvk.tar.gz; \
    ls /opt/dxvk-2.4.1/x32/d3d9.dll

# Drop sway's file capability (cap_sys_nice) to keep cap-drop=ALL viable rootless
RUN setcap -r /usr/bin/sway 2>/dev/null || true

# Configs
COPY sway.config /etc/sway/config
COPY sunshine.conf /etc/sunshine/sunshine.conf
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY build-prefix.sh /usr/local/bin/build-prefix.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/build-prefix.sh

ENV XDG_RUNTIME_DIR=/run/user/1000 \
    WLR_BACKENDS=headless \
    WLR_RENDERER=gles2 \
    LIBSEAT_BACKEND=noop \
    LIBVA_DRIVER_NAME=radeonsi \
    AMD_VULKAN_ICD=RADV \
    WINEPREFIX=/home/wine/.wine \
    WINEARCH=win64 \
    WINEESYNC=1 WINEFSYNC=1 WINE_LARGE_ADDRESS_AWARE=1 \
    WINEDEBUG=-all \
    DXVK_STATE_CACHE_PATH=/home/wine/.cache

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
