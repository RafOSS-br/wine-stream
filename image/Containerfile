# wine-stream: hardened, rootless container for Windows executables.
# Stage 1: build Sunshine "legacy" (XTest input backend).
# Stage 2: lean runtime (Sway + Xwayland + Wine + DXVK + Mesa/VAAPI).

# ===== Stage 1: Sunshine legacy (XTest) — only tag with -DSUNSHINE_USE_LEGACY_INPUT =====
FROM registry.fedoraproject.org/fedora:43 AS sunshine-build
RUN dnf -y install gcc gcc-c++ cmake ninja-build git rpm-build nodejs npm \
    boost-devel libcap-devel libcurl-devel libdrm-devel libevdev-devel \
    libva-devel libvdpau-devel libX11-devel libxcb-devel libXcursor-devel \
    libXfixes-devel libXi-devel libXinerama-devel libXrandr-devel libXtst-devel \
    mesa-libGL-devel miniupnpc-devel numactl-devel openssl-devel opus-devel \
    pulseaudio-libs-devel wayland-devel libdisplay-info-devel \
    wget which && dnf clean all
WORKDIR /src
RUN git clone --branch v2025.118.151840 --depth 1 --recurse-submodules \
    https://github.com/LizardByte/Sunshine.git .
RUN dnf -y install libnotify-devel libappindicator-gtk3-devel doxygen graphviz && dnf clean all
# fc43: miniupnpc header uses size_t without including stddef.h -> inject it
RUN sed -i '1i #include <stddef.h>' /usr/include/miniupnpc/upnpcommands.h
WORKDIR /src/build
RUN cmake -G Ninja \
    -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr \
    -DSUNSHINE_USE_LEGACY_INPUT=ON -DSUNSHINE_ENABLE_TRAY=OFF \
    -DSUNSHINE_ENABLE_X11=ON -DSUNSHINE_ENABLE_WAYLAND=ON -DSUNSHINE_ENABLE_DRM=OFF \
    -DSUNSHINE_ENABLE_CUDA=OFF -DBUILD_TESTS=OFF \
    -DSUNSHINE_ASSETS_DIR=share/sunshine -DSUNSHINE_EXECUTABLE_PATH=/usr/bin/sunshine \
    /src && ninja && cpack -G RPM

# ===== Stage 2: runtime =====
FROM registry.fedoraproject.org/fedora:43

# RPM Fusion (mesa-va-drivers-freeworld: H264/HEVC encode)
RUN dnf install -y \
      https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
      https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm \
 && dnf clean all

# Sway + Xwayland + Wine + Mesa/VAAPI + debug tools (grim/xdotool/vulkan-tools)
RUN dnf install -y \
      sway \
      mesa-vulkan-drivers mesa-dri-drivers mesa-libGL vulkan-loader vulkan-tools \
      xorg-x11-server-Xwayland \
      libva libva-utils \
      pipewire pipewire-pulseaudio pipewire-utils wireplumber \
      wine winetricks \
      dbus-daemon \
      curl tar which procps-ng cabextract grim xdotool \
 && dnf clean all

RUN dnf swap -y mesa-va-drivers mesa-va-drivers-freeworld || \
    dnf install -y --allowerasing mesa-va-drivers-freeworld

# 32-bit libs for PE32 i386 executables under Wine with GPU
RUN dnf install -y \
      mesa-vulkan-drivers.i686 vulkan-loader.i686 \
      mesa-dri-drivers.i686 mesa-libGL.i686 alsa-lib.i686 \
 && dnf clean all

# Sunshine legacy (XTest) from the build stage
COPY --from=sunshine-build /src/build/cpack_artifacts/Sunshine.rpm /tmp/sunshine.rpm
RUN dnf install -y /tmp/sunshine.rpm binutils && rm -f /tmp/sunshine.rpm && \
    strings /usr/bin/sunshine | grep -q XTestFakeButtonEvent && \
    dnf remove -y binutils && dnf clean all    # gate: XTest symbols present

# DXVK (D3D8-D3D11 over Vulkan)
RUN set -eux; \
    curl -L -o /tmp/dxvk.tar.gz \
      https://github.com/doitsujin/dxvk/releases/download/v2.4.1/dxvk-2.4.1.tar.gz; \
    mkdir -p /opt; tar -C /opt -xf /tmp/dxvk.tar.gz; rm /tmp/dxvk.tar.gz; \
    ls /opt/dxvk-2.4.1/x32/d3d9.dll

# Drop sway's file capability (cap_sys_nice) to keep cap-drop=ALL viable rootless
RUN setcap -r /usr/bin/sway 2>/dev/null || true

# Configs
COPY sway.config /etc/sway/config
COPY sunshine.conf /etc/sunshine/sunshine.conf
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY build-prefix.sh /usr/local/bin/build-prefix.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/build-prefix.sh

ENV XDG_RUNTIME_DIR=/run/user/1000 \
    WLR_BACKENDS=headless \
    WLR_RENDERER=gles2 \
    LIBSEAT_BACKEND=noop \
    LIBVA_DRIVER_NAME=radeonsi \
    AMD_VULKAN_ICD=RADV \
    WINEPREFIX=/home/wine/.wine \
    WINEARCH=win64 \
    WINEESYNC=1 WINEFSYNC=1 WINE_LARGE_ADDRESS_AWARE=1 \
    WINEDEBUG=-all \
    DXVK_STATE_CACHE_PATH=/home/wine/.cache

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
