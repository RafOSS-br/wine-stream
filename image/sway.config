# Headless Sway: top-level compositor exposing wlr-screencopy for Sunshine.

output HEADLESS-1 resolution 1920x1080 position 0 0

default_border none
default_floating_border none
gaps inner 0
gaps outer 0
focus_follows_mouse no

# Single app window, borderless, fills the output (tiled).
for_window [shell="xwayland"] border none

# Cursor: the app must draw its own cursor in-frame (e.g. WoW: SET gxCursor "0").
# Hardware cursors are invisible here: XTest moves only the X11 pointer, the
# compositor's Wayland pointer never moves, so screencopy has no cursor to draw.
